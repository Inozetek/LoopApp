# Loop App Environment Variables
# Copy this file to .env and fill in your actual values

# === REQUIRED: Supabase Configuration ===
# Get these from: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# === REQUIRED: Facebook OAuth ===
# Get these from: https://developers.facebook.com/apps/
# 1. Create Facebook App
# 2. Add Facebook Login product
# 3. Copy App ID and App Secret
EXPO_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# === OPTIONAL: Google Places API Key ===
# Get yours at: https://console.cloud.google.com/apis/credentials
# Note: App will use mock data if this is not provided
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_key_here

# === OPTIONAL: Unsplash API (for fallback images) ===
# Get yours at: https://unsplash.com/developers
# Free tier: 50 requests/hour
# Used when Google Places doesn't have venue photos
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=your_access_key_here

# === OPTIONAL: Sentry Error Tracking ===
# Get your DSN from: https://sentry.io/settings/projects/<your-project>/keys/
# Used for production error monitoring and crash reporting.
#
# EXPO_PUBLIC_SENTRY_DSN  — inlined into the JS bundle (required for RN SDK).
# SENTRY_ORG / SENTRY_PROJECT / SENTRY_AUTH_TOKEN — used by the Expo build
# plugin to upload source maps during EAS builds (set as EAS secrets in CI).
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_ORG=your_sentry_org_here
SENTRY_PROJECT=your_sentry_project_here
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# === OPTIONAL: Analytics ===
# PostHog (recommended for product analytics)
# Get from: https://posthog.com/
EXPO_PUBLIC_POSTHOG_API_KEY=your_posthog_api_key_here
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# OR Mixpanel (alternative analytics platform)
# Get from: https://mixpanel.com/
# EXPO_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token_here

# === OPTIONAL: Gemini AI (for AI-generated place descriptions) ===
# Free tier: 1,500 req/day, 1M tokens/day
# Get yours at: https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your_key_here

# === FUTURE: OpenAI API (for enhanced AI explanations - Phase 2) ===
# Get yours at: https://platform.openai.com/api-keys
# EXPO_PUBLIC_OPENAI_API_KEY=sk-...

# === REQUIRED: Google OAuth ===
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here

# === REQUIRED: Google Maps SDK (for map rendering in iOS/Android) ===
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# === SERVER-SIDE ONLY: Supabase Service Role Key ===
# Only needed for local scripts/seeding — Edge Functions get this automatically
# NEVER put this in client code or EXPO_PUBLIC_ prefixed vars
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# Multi-Source Integration (Phase 1-2)
# ============================================

# Feature Flags (set to 'false' to disable)
EXPO_PUBLIC_ENABLE_TICKETMASTER=true
EXPO_PUBLIC_ENABLE_EVENTBRITE=false
EXPO_PUBLIC_ENABLE_GROUPON=false
EXPO_PUBLIC_ENABLE_YELP=false
EXPO_PUBLIC_ENABLE_SONGKICK=false
EXPO_PUBLIC_ENABLE_MIXED_FEED=true
EXPO_PUBLIC_ENABLE_BOTTOM_SHEETS=false

# Cost control: set to 'true' to disable live Google Places API calls (cache-only)
EXPO_PUBLIC_DISABLE_GOOGLE_PLACES_API=false

# Ticketmaster Discovery API (free tier: 5000 req/day)
# Get your key at: https://developer.ticketmaster.com/
EXPO_PUBLIC_TICKETMASTER_API_KEY=your_ticketmaster_key_here

# Eventbrite API (search endpoint deprecated Feb 2020 — limited use)
EXPO_PUBLIC_EVENTBRITE_API_KEY=your_eventbrite_key_here

# === FUTURE: Additional services (Phase 2+) ===
# OpenWeather API for weather-based recommendations
# EXPO_PUBLIC_WEATHER_API_KEY=...

# Google Maps Directions/Traffic API
# EXPO_PUBLIC_MAPS_API_KEY=...

# === OPTIONAL: Stripe Payments ===
# Publishable key (safe for client-side, used by the Stripe SDK)
# Get yours at: https://dashboard.stripe.com/apikeys
# Use test-mode key (pk_test_...) during development
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY
# IMPORTANT: NEVER put the secret key (sk_...) in client code!
# The secret key goes in your Supabase Edge Function environment:
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...

# === DEVELOPMENT OPTIONS ===
# Enable mock data mode (bypasses all external APIs for testing)
# EXPO_PUBLIC_MOCK_MODE=true

# Enable verbose debug logging
# EXPO_PUBLIC_DEBUG_MODE=true
